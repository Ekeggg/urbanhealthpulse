generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model SymptomLog {
  id        String   @id @default(cuid())
  userId    String
  date      DateTime @default(now())
  symptoms  String
  severity  Int
  district  String
  lat       Float
  lng       Float
  notes     String?
}
